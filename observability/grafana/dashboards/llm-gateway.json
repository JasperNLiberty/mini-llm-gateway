{
  "uid": "llm-gateway",
  "title": "LLM Gateway — Performance & Cost",
  "tags": ["llm", "inference", "cost"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Live $/M tokens",
      "description": "Rolling cost per million tokens at the configured GPU rate. The single number the industry quotes prices in.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "cost_per_million_tokens", "legendFormat": "$/M" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Cost / request (p95)",
      "description": "95th-percentile dollar cost of a single request over the rolling window.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 6 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "cost_per_request_p95_usd", "legendFormat": "p95 $/req" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Session total cost",
      "description": "Cumulative dollars spent since the gateway process started.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 6 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "cost_session_total_usd", "legendFormat": "session $" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "GPU rate ($/hr)",
      "description": "The economic input driving all cost math (GPU_HOURLY_RATE).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none", "textMode": "auto" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "gpu_hourly_rate_usd", "legendFormat": "$/hr" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Effective $/M (utilization-adjusted) vs nominal",
      "description": "Nominal $/M assumes a busy GPU. Effective = nominal / utilization (floored at 0.05 to cap the idle blow-up) — the idle GPU you still pay for. This is the 'your $/token is higher than the spec sheet' effect, live.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "cost_per_million_tokens", "legendFormat": "nominal $/M" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "cost_per_million_tokens / clamp_min(avg_over_time(gpu_slots_utilization[5m]), 0.05)", "legendFormat": "effective $/M" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Slot utilization",
      "description": "Fraction of concurrency slots in use (proxy for GPU utilization). Sampled at scrape time.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "gpu_slots_utilization", "legendFormat": "utilization" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request latency percentiles",
      "description": "p50 / p95 / p99 end-to-end request latency.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum(rate(chat_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum(rate(chat_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum(rate(chat_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Throughput (tokens/sec)",
      "description": "Output tokens generated per second across all models.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(tokens_generated_total[1m]))", "legendFormat": "tok/s" }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Request rate by status",
      "description": "Successful vs errored requests per second.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(chat_requests_total[1m])) by (status)", "legendFormat": "{{status}}" }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "In-flight & queue depth",
      "description": "Requests currently processing vs waiting for a concurrency slot. Queue depth climbing is the backpressure / head-of-line signal.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "chat_in_flight", "legendFormat": "in-flight" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "chat_queue_depth", "legendFormat": "queued" }
      ]
    }
  ]
}
